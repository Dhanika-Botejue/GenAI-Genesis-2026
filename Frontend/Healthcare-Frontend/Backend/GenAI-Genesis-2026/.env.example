# ------------------------------------------------------------------------------
# Speech: ElevenLabs (preferred) or IBM Watson
# ------------------------------------------------------------------------------

# ElevenLabs — used for TTS and STT when set (replaces IBM)
ELEVENLABS_API_KEY=
# Optional: XI_API_KEY is an alias for ELEVENLABS_API_KEY
# XI_API_KEY=
# Optional: voice ID (default: EXAVITQu4vr4xnSDxMaL)
# ELEVENLABS_VOICE_ID=
# Optional: TTS model (default: eleven_monolingual_v1)
# ELEVENLABS_MODEL_ID=
# Optional: STT model (default: scribe_v1)
# ELEVENLABS_STT_MODEL=

# IBM Watson (only needed if ELEVENLABS_API_KEY is not set, or for local voice chatbot)
STT_API_KEY=
STT_URL=
TTS_API_KEY=
TTS_URL=

# IBM WatsonX (LLM reasoning + care note generation)
IBM_WATSONX_API_KEY=
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_PROJECT_ID=
IBM_WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# ------------------------------------------------------------------------------
# Optional LLM providers
# ------------------------------------------------------------------------------

# OpenRouter fallback summary for local voice sessions
OPENROUTER_API_KEY=

# OpenAI classification used in Twilio turn handling (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# Twilio outbound calling and webhook routing
# ------------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public HTTPS URL reachable by Twilio (example: ngrok URL)
PUBLIC_BASE_URL=

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# If set, backend uses MongoDB; if omitted some routes may use in-memory fallback
MONGODB_URI=

# ------------------------------------------------------------------------------
# Runtime toggles and tuning
# ------------------------------------------------------------------------------

# Start local microphone chatbot inside FastAPI lifespan
ENABLE_LOCAL_VOICE_CHATBOT=0

# Voice chatbot mic index override (leave blank for auto-select)
MIC_DEVICE_INDEX=

# Twilio/STT behavior
TWILIO_FAST_TURNS=1
TWILIO_STT_MODEL=en-US_Telephony

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# Use "*" for development. For production set to your Vercel URL, e.g.:
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=*
TWILIO_RECORD_TIMEOUT_SECONDS=2
TWILIO_RECORD_MAX_LENGTH_SECONDS=20
TWILIO_RECORD_TRIM=trim-silence
TWILIO_CACHE_PROMPT_AUDIO=1

# GPT classification timeout in seconds
OPENAI_CLASSIFICATION_TIMEOUT_SECONDS=3.5

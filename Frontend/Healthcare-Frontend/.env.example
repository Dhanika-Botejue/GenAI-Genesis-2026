NEXT_PUBLIC_UPLOAD_MAX_MB=15
NEXT_PUBLIC_ANALYSIS_MAX_SIDE_PX=1800

# Set to "false" to disable mock patient data on the 3D floorplan.
# Default is true (mock patients are shown on startup).
NEXT_PUBLIC_MOCK_PATIENTS=true

# Backend base URL for the Doctor workspace proxy (server-side only).
# In development this points to your local FastAPI server.
# In production (Vercel) set this in the Vercel dashboard Environment Variables
# to your Vultr backend URL, e.g.: https://your-vultr-domain-or-ip:5000
# Do NOT prefix with NEXT_PUBLIC_ in production — it must stay server-side.
DOCTOR_API_BASE_URL=http://127.0.0.1:5000
